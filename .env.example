# StableRoute backend local environment template.
# Copy this file to .env if your local process manager loads dotenv files.

# HTTP port for the Express server.
PORT=3001

# Runtime mode. Use "test" only for Jest, because it disables request logs and
# the in-memory rate limiter.
NODE_ENV=development

# Reserved for upcoming admin endpoints. Leave blank until admin auth lands.
ADMIN_TOKEN=

# Reserved for upcoming CORS configuration. Leave blank to use the current
# default CORS behavior.
CORS_ALLOWED_ORIGINS=

# Reserved for upcoming proxy-aware deployment support.
TRUST_PROXY=false

# Reserved for upcoming structured logging configuration.
LOG_LEVEL=info
