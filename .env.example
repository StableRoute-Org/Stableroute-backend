# HTTP port for the Express server.
# Runtime default: 3001
PORT=3001

# Node runtime mode.
# Use "test" for automated tests; request logging and rate limiting are disabled
# in test mode so suites can run deterministically.
NODE_ENV=development

# Reserved for upcoming admin endpoint authentication.
# Leave unset until admin auth support is implemented.
# ADMIN_TOKEN=

# Reserved for upcoming CORS allowlist support.
# Expected future format: comma-separated origins.
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Reserved for upcoming proxy-aware rate limiting.
# Expected future values: true or false.
# TRUST_PROXY=false

# Reserved for upcoming structured logger configuration.
# Expected future values: debug, info, warn, error.
# LOG_LEVEL=info
