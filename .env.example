# HTTP port used by src/server.ts.
PORT=3001

# Runtime mode. Use "production" in deployed environments and "test" for Jest.
NODE_ENV=development

# Reserved for the admin-route guard. Leave empty in local development.
ADMIN_TOKEN=

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Reserved for deployments behind a trusted reverse proxy.
TRUST_PROXY=false

# Reserved for future structured logging controls.
LOG_LEVEL=info
