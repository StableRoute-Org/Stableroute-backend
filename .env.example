# StableRoute backend local configuration.
# Copy this file to `.env` for local overrides. Keep `.env` out of git.

# HTTP port used by src/index.ts and src/server.ts.
# Default: 3001.
PORT=3001

# Runtime mode. Tests use NODE_ENV=test to suppress request logging noise.
# Default: development.
NODE_ENV=development

# Reserved for admin-only endpoints in upcoming work. Leave empty locally until
# an admin route requires it. Use a strong, non-public token outside local dev.
ADMIN_TOKEN=

# Reserved for configurable CORS allowlists in upcoming work.
# Comma-separated origins, for example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Reserved for proxy-aware Express deployments in upcoming work.
# Set to true only when the app is behind a trusted reverse proxy.
TRUST_PROXY=false

# Reserved for structured logging in upcoming work.
# Suggested values: debug, info, warn, error.
LOG_LEVEL=info
